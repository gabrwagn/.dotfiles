
# Prompt customization
autoload -Uz vcs_info
precmd() { vcs_info }
zstyle ':vcs_info:git:*' formats ' %b'

setopt PROMPT_SUBST
NEWLINE=$'\n'

if [[ -n $SSH_CONNECTION ]]; then
  SSH_INDICATOR='%F{yellow} [ssh %m] %f'
else
  SSH_INDICATOR=''
fi

PROMPT='%B%F{blue}󰉋 %(3~|../%2~|%~)%f %F{red}${vcs_info_msg_0_}${SSH_INDICATOR}${NEWLINE}%F{13}>%f%b '
RPROMPT='%F{13}[%D{%H:%M:%S}]'
